{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=LeaveManagement;Username=postgres;Password=yourpassword"
  },
  "JwtSettings": {
    "Key": "YOUR_JWT_SECRET_KEY_MIN_32_CHARS",
